{
  "name": "megoogle",
  "version": "1.0.0",
  "description": "Antigravity Codex v6.0 with Code Studio and desktop app",
  "main": "desktop/main.cjs",
  "scripts": {
    "start:backend": "node server/index.js",
    "start:frontend": "python3 -m http.server 8765",
    "start:desktop": "electron .",
    "build:mac-app": "electron-packager . \"Antigravity Codex\" --platform=darwin --arch=arm64 --out=dist --overwrite --app-version=6.1.0 --icon=assets/icon.icns --prune=true",
    "test": "node --check server/index.js && node --check desktop/main.cjs"
  },
